# Server
PORT=8000
ENV=development

# Meta WhatsApp Cloud API
WA_VERIFY_TOKEN=
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_APP_SECRET=

# LLM / STT
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_ESCALATION_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=

# Data — local dev points at your pgAdmin-managed Postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stokipa

SQL_ECHO=false