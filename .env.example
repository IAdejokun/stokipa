# Server
PORT=8000
ENV=development

# Meta WhatsApp Cloud API
WA_VERIFY_TOKEN=
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_APP_SECRET=

# LLM / STT
LLM_API_KEY=
